# El CLI de Vercel sube desde la raiz del repo git, no desde rootDirectory, y no
# lee .gitignore. Esto espeja las exclusiones de .gitignore para que el upload no
# arrastre los datasets: data-fallback pesa ~160 MB y revienta el limite de 100 MB.

data-fallback/
starter-assets/
create-questions/
*.pdf

node_modules/
.next/
.vercel/

.claude/
.codex/
*.md
